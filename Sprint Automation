# Global variables to store Jira URL and authentication details
jira_url = None
auth = None

def clear_form():
    # Hide the form fields
    for widget in form_frame.winfo_children():
        widget.grid_forget()

def jira_connect_form():
    clear_form()
    # Create and place the labels and entry widgets with padding
    tk.Label(form_frame, text="Jira URL:").grid(row=0, column=0, padx=10, pady=10)
    url_combobox.grid(row=0, column=1, padx=10, pady=10)
    url_combobox.current(0)  # Set the default value
    
    tk.Label(form_frame, text="Username:").grid(row=1, column=0, padx=10, pady=10)
    username_entry.grid(row=1, column=1, padx=10, pady=10)
    
    tk.Label(form_frame, text="Password:").grid(row=2, column=0, padx=10, pady=10)
    password_entry.grid(row=2, column=1, padx=10, pady=10)
      
    # Create and place the connect button with padding
    connect_button.grid(row=3, columnspan=2, padx=10, pady=20)
 
def connect_to_jira():
    global jira_url, auth
    jira_url = url_combobox.get()
    username = username_entry.get()
    password = password_entry.get()
    
    auth = (username, password)
    headers = {
        "Content-Type": "application/json"
    }
    
    try:
        # Make a request to Jira to verify the connection
        jira = requests.get(jira_url, auth=auth, headers=headers, verify=False)
        
        if jira.status_code == 200:
            messagebox.showinfo("Success", "Connected to Jira successfully!")
            clear_form()  # Clears the form window
            return jira_url, auth
            
        else:
            messagebox.showerror("Error", f"Failed to connect to Jira: {jira.status_code}")
            return None, None
    except requests.exceptions.RequestException as e:
        messagebox.showerror("Error", f"An error occurred: {e}")
        return None, None

